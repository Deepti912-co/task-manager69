# Copy this file to .env and paste your Gemini API key.
# Never commit the real key.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: the server defaults to 4173 when PORT is not set.
# PORT=4173

# Optional production database for reminders. When these are present and userId is a UUID,
# reminders and push subscriptions are stored in Supabase instead of the local dev fallback.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Reliable reminders / Web Push. Generate VAPID keys with a standard Web Push tool.
# VAPID_SUBJECT should be a mailto: or HTTPS URL controlled by you.
VAPID_PUBLIC_KEY=your_urlsafe_base64_public_vapid_key
VAPID_PRIVATE_KEY=your_urlsafe_base64_private_vapid_key
VAPID_SUBJECT=mailto:admin@example.com

# Optional: protect /api/cron/reminders when called by hosted cron infrastructure.
CRON_SECRET=replace_with_a_long_random_value
